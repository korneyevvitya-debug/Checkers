<Window x:Class="Checkers.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Checkers"
        mc:Ignorable="d"
        Title="Шашки" Height="450" Width="800">
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="100"/>
			<RowDefinition Height="100"/>
			<RowDefinition Height="100"/>
			<RowDefinition/>
		</Grid.RowDefinitions>
		<Button Content="Новая игра на двоих" Click="StartTwoPlayer"
                Grid.Row="0" Width="200" Background="DimGray" Foreground="White"/>
		<Button Content="Новая игра с компьютером" Click="StartVsComputer"
                Grid.Row="1" Width="200" Background="DimGray" Foreground="White"/>
		<Button Content="Продолжить игру" Click="ContinueGame"
                Grid.Row="2" Width="200" Background="DimGray" Foreground="White"
                x:Name="ContinueButton"/>
	</Grid>
</Window>