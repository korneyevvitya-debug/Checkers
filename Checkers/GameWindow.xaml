        <Grid Grid.Row="1" Width ="300" Height="300" HorizontalAlignment="Left" Margin="50 0 0 0" Background ="Gray" x:Name="TestBorder" >
            <Grid x:Name ="gameGrid">
               
            </Grid>
            <Grid x:Name="Moves">
                
            </Grid>
            <Grid x:Name="Checkers">
                
            </Grid>
        </Grid>
    </Grid>
</Window>
